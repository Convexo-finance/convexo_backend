# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://your-service.up.railway.app
FRONTEND_URL=https://your-frontend.vercel.app

# ─── Database ─────────────────────────────────────────────────────────────────
# On Railway: set as ${{Postgres.DATABASE_URL}} reference variable
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Redis ────────────────────────────────────────────────────────────────────
# On Railway: set as ${{Redis.REDIS_URL}} reference variable
REDIS_URL=redis://host:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=your-strong-secret-minimum-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Pinata IPFS ──────────────────────────────────────────────────────────────
PINATA_JWT=
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_GATEWAY=lime-famous-condor-7.mypinata.cloud

# ─── Veriff (Individual KYC) ──────────────────────────────────────────────────
VERIFF_API_KEY=
VERIFF_BASE_URL=https://stationapi.veriff.com
VERIFF_WEBHOOK_SECRET=

# ─── Sumsub (Business KYB) ────────────────────────────────────────────────────
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_WEBHOOK_SECRET=

# ─── n8n (Credit Score Automation) ───────────────────────────────────────────
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# ─── Notifications ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=financial@convexo.org
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPS_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=

# ─── Blockchain RPC (read-only) ───────────────────────────────────────────────
BASE_MAINNET_RPC_URL=https://base-mainnet.infura.io/v3/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.infura.io/v3/YOUR_KEY
UNICHAIN_MAINNET_RPC_URL=https://mainnet.unichain.org
UNICHAIN_SEPOLIA_RPC_URL=https://sepolia.unichain.org

# ─── Exchange Rates ───────────────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=
RATES_CACHE_TTL_SECONDS=600

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Admin Bootstrap ──────────────────────────────────────────────────────────
# Comma-separated wallet addresses granted SUPER_ADMIN on startup
ADMIN_WALLET_ADDRESSES=
